# ════════════════════════════════════════════════════════════
#  Sistem Pantau Kehadiran Pelajar — contoh .env
#  Salin fail ini ke `.env` dan isi nilai sebenar:
#     cp .env.example .env
#  JANGAN commit .env ke GitHub (sudah ada dalam .gitignore).
# ════════════════════════════════════════════════════════════

# ── Aplikasi ──
NODE_ENV=production
APP_PORT=3000
TIMEZONE=Asia/Kuala_Lumpur

# ── PostgreSQL ──
DB_USER=kehadiran
DB_PASSWORD=GANTI_KATA_LALUAN_KUAT_DI_SINI
DB_NAME=kehadiran
# Port untuk akses dari server (pgAdmin/psql) — terikat ke 127.0.0.1 sahaja
DB_PORT_HOST=5432
# Jalankan schema secara automatik ketika app start (idempotent)
RUN_MIGRATIONS_ON_START=true
# Semai pengguna awal (superadmin/admin) ketika app start (idempotent)
RUN_SEED_ON_START=true

# ── Autentikasi & Sesi (Fasa 8) ──
# Rahsia tandatangan cookie sesi. WAJIB ganti. Jana: openssl rand -hex 32
SESSION_SECRET=GANTI_RAHSIA_SESI_DI_SINI
# Tempoh sah sesi (milisaat); lalai 8 jam = 28800000
SESSION_MAX_AGE_MS=28800000

# Kelayakan seed awal — DIPAKAI SEKALI sahaja (ON CONFLICT DO NOTHING).
# Selepas log masuk pertama, TUKAR kata laluan via /api/auth/tukar-kata-laluan.
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_PASSWORD=GANTI_KATA_LALUAN_SUPERADMIN
SEED_SUPERADMIN_NAMA=SU HEM
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=GANTI_KATA_LALUAN_ADMIN
SEED_ADMIN_NAMA=SU Kehadiran

# (Legacy) JWT_SECRET tidak lagi digunakan — digantikan sesi cookie di atas.
# JWT_SECRET=

# ── Google Sheets (Fasa 2) — READ-ONLY. Sheet #2 = master ──
# Path ke fail kunci service account (letak fail dalam folder ./secrets/)
GOOGLE_APPLICATION_CREDENTIALS=secrets/service-account.json
# Sheet #1 (rujukan guru kelas + pembantu guru kelas)
SHEET_MASTER_PELAJAR_ID=1kZJRFxl_d2TrOHcfVMqOOzUwfBC-NGWbI3uFUpT-Bc4
# Sheet #2 (master utama kehadiran/peratus)
SHEET_KEHADIRAN_ID=16_MSYusUPXlVbATXrWdtwHFvKiaq5tD4s07XwsbEEC0

# ── Telegram (Fasa 8) ──
# K4: token lama DIANGGAP TERDEDAH — JANGAN guna semula.
# Biarkan kosong sehingga Fasa 8; token BARU akan dijana & diletak di sini.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
